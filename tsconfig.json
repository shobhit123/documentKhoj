{
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@atoms/*": ["src/components/atoms/*"],
      "@components/*": ["src/components/*"]
    },   
    "jsx": "react",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src"]
}
